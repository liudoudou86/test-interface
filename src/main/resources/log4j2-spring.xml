<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorinterval="500">
    <Properties>
        <Property name="LOG_HOME">target/log/interface</Property>
        <property name="FILE_NAME">test-interface</property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%style{%-d{yyyy-MM-dd HH:mm:ss}}{bright,white} [%style{%t:%r}{blue}] - [%highlight{%p}:%clr{%c{1}}{magenta}] - %style{%l}{cyan} - %m%n"/>
        </Console>
        <RollingRandomAccessFile name="RollingRandomAccessFile" fileName="${LOG_HOME}/${FILE_NAME}.log"
                                 filePattern="${LOG_HOME}/${date:yyyy-MM-dd}/${FILE_NAME}-%d{yyyy-MM-dd HH-mm}-%i.log"
                                 append="true" immediateFlush="false">
            <PatternLayout pattern="%-d{yyyy-MM-dd HH:mm:ss} [%t:%r] - [%p:%c{1}] - %l - %m%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="1MB"/>
            </Policies>
        </RollingRandomAccessFile>
    </Appenders>
    <loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </loggers>
</Configuration>